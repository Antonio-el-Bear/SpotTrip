{
  "name": "tourguide-frontend-fresh",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "amadeus": "^11.0.0",
    "next": "^16.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next dev -H 0.0.0.0",
    "serve": "next start",
    "share:start": "powershell -ExecutionPolicy Bypass -File ./scripts/share-session.ps1",
    "share:stop": "powershell -ExecutionPolicy Bypass -File ./stop-all.ps1",
    "launcher:build": "dotnet publish ./launcher/TravelRecordLauncher/TravelRecordLauncher.csproj -c Release -r win-x64 --self-contained false -p:PublishSingleFile=true -o ./launcher/publish",
    "smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1",
    "smoke:write": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1 -IncludeWriteCheck"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
